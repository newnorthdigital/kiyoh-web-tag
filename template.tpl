___TESTS___

scenarios:
- name: Basic invite request
  code: |-
    var mockData = {
      hash: 'abc123hash',
      locationId: '1234',
      tenantId: '98',
      inviteEmail: 'customer@example.com',
      delay: '0',
      language: 'nl',
      debug: true
    };

    mock('sendPixel', function(url, onSuccess, onFailure) {
      onSuccess();
    });

    runCode(mockData);

    assertApi('sendPixel').wasCalled();
    assertApi('gtmOnSuccess').wasCalled();

