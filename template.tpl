___SANDBOXED_JS_FOR_WEB_TEMPLATE___

var log = require('logToConsole');
var sendPixel = require('sendPixel');
var encodeUriComponent = require('encodeUriComponent');
var makeString = require('makeString');

var enableDebug = data.debug;
var debugLog = function(msg) {
  if (enableDebug) log('Kiyoh GTM - ' + msg);
};

// Build the invite URL
var baseUrl = 'https://www.kiyoh.com/v1/invite/external';
var params = '?hash=' + encodeUriComponent(makeString(data.hash));
params = params + '&location_id=' + encodeUriComponent(makeString(data.locationId));
params = params + '&tenantId=' + encodeUriComponent(makeString(data.tenantId));
params = params + '&invite_email=' + encodeUriComponent(makeString(data.inviteEmail));

if (data.firstName) {
  params = params + '&first_name=' + encodeUriComponent(makeString(data.firstName));
}
if (data.lastName) {
  params = params + '&last_name=' + encodeUriComponent(makeString(data.lastName));
}
if (data.refCode) {
  params = params + '&ref_code=' + encodeUriComponent(makeString(data.refCode));
}

params = params + '&delay=' + encodeUriComponent(makeString(data.delay || '0'));
params = params + '&language=' + encodeUriComponent(makeString(data.language || 'nl'));

var inviteUrl = baseUrl + params;

debugLog('Sending review invite for order: ' + makeString(data.refCode || 'N/A'));

// Fire the invite request via sendPixel (GET request)
// The API returns JSON, not an image, so onSuccess may not fire
// But the request is still sent and processed by Kiyoh
sendPixel(inviteUrl, function() {
  debugLog('Invite request completed');
}, function() {
  debugLog('Invite pixel response received (non-image, expected)');
});

// Always succeed since the request is fire-and-forget
data.gtmOnSuccess();


